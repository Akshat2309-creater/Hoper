# Optional: Google Sign-In on the login page (Google Identity Services).
# Create an OAuth 2.0 Web client ID in Google Cloud Console and paste it here.
# VITE_GOOGLE_CLIENT_ID=

# Production: URL of your FastAPI backend (no trailing slash). Chat + voice transcription call this host.
# Dev default is http://localhost:8000 if unset.
# VITE_API_BASE_URL=https://your-api.example.com
